{
  "name": "agent-deck",
  "private": true,
  "workspaces": [
    "packages/shared",
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n be,fe -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node apps/backend/src/index.js",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "build": "npm run build --workspace=apps/frontend",
    "test": "npm test --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.9"
  }
}
